@page "/budget"
@inject MRIImport.Core.Handlers.BudgetHandler Handler

@* ══════════════════════════════════════════════════════════════════════════
   Budget import page.
   Page-specific control: "Update existing records" checkbox.
   When checked, the handler uses SQL MERGE (upsert) instead of plain INSERT.
   Called from MRI as: /budget?db=BCP_PROD&UserId=jsmith
   ══════════════════════════════════════════════════════════════════════════ *@

<ImportPage Handler="@Handler" GetExtraParameters="@GetExtras">
    <ChildContent>
        <MudCheckBox @bind-Value="_updateExisting"
                     Label="Update existing records"
                     Color="Color.Primary"
                     Size="Size.Small" />
    </ChildContent>
</ImportPage>

@code {
    private bool _updateExisting;

    private Dictionary<string, string> GetExtras() => new()
    {
        ["updateExisting"] = _updateExisting.ToString()
    };
}
